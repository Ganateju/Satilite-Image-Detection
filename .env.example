# Required environment variables for Satellite Change Detector
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# -----------------------------------------------------------------
# Google Earth Engine
# -----------------------------------------------------------------

# Your GEE Cloud Project ID
# Create one at: https://console.cloud.google.com/
GEE_PROJECT_ID=

# (Optional) Path to a GEE Service Account JSON key file.
# Leave blank if you authenticate via `earthengine authenticate` CLI.
GEE_SERVICE_ACCOUNT_KEY_PATH=
